<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Lets heapscope attach via task_for_pid. Swift's auto-applied
         linker-signed ad-hoc signature does NOT include this anymore, so we
         have to set it explicitly. Without it, taskgated-platform denies the
         attach even when the caller is root + carries cs.debugger. -->
    <key>com.apple.security.get-task-allow</key>
    <true/>
</dict>
</plist>
